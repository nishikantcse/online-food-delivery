{
  "dashboard": {
    "title": "Online Food Delivery Observability",
    "panels": [
      {
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{job}}"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
            "legendFormat": "{{job}} errors"
          }
        ]
      },
      {
        "title": "Response Duration (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{job}} p95"
          }
        ]
      },
      {
        "title": "Orders Placed",
        "type": "stat",
        "targets": [
          {
            "expr": "orders_placed_total",
            "legendFormat": "Total Orders"
          }
        ]
      }
    ]
  }
}